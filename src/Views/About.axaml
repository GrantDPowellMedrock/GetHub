<v:ChromelessWindow xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:v="using:GetHub.Views"
                    mc:Ignorable="d" d:DesignWidth="640" d:DesignHeight="320"
                    x:Class="GetHub.Views.About"
                    x:Name="ThisControl"
                    Icon="/App.ico"
                    Title="{DynamicResource Text.About}"
                    SizeToContent="WidthAndHeight"
                    CanResize="False"
                    WindowStartupLocation="CenterOwner">
  <StackPanel Orientation="Vertical">
    <!-- TitleBar -->
    <Grid Height="28" IsVisible="{Binding !#ThisControl.UseSystemWindowFrame}">
      <Border Background="{DynamicResource Brush.TitleBar}"
              BorderThickness="0,0,0,1" BorderBrush="{DynamicResource Brush.Border0}"
              PointerPressed="BeginMoveWindow"/>

      <Path Width="14" Height="14"
            Margin="10,0,0,0"
            HorizontalAlignment="Left"
            Data="{StaticResource Icons.Info}"
            IsVisible="{OnPlatform True, macOS=False}"/>

      <TextBlock Classes="bold"
                 Text="{DynamicResource Text.About}"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 IsHitTestVisible="False"/>

      <v:CaptionButtons HorizontalAlignment="Right"
                        IsCloseButtonOnly="True"
                        IsVisible="{OnPlatform True, macOS=False}"/>
    </Grid>

    <!-- Content -->
    <StackPanel Orientation="Horizontal">
      <Image Width="200" Height="200"
             Margin="8,0"
             Source="/App.ico"
             HorizontalAlignment="Center"
             VerticalAlignment="Center"/>

      <StackPanel Orientation="Vertical" Margin="4,18,24,18">
        <StackPanel Height="40" Orientation="Horizontal">
          <TextBlock Classes="bold" Text="GetHub" FontSize="32" />
          <Border Margin="12,0,0,0" Height="20"
                  CornerRadius="10"
                  Background="{DynamicResource Brush.Accent}"
                  Effect="drop-shadow(0 0 6 #40000000)"
                  Cursor="Hand"
                  PointerPressed="OnVisitReleaseNotes"
                  ToolTip.Tip="{DynamicResource Text.About.ReleaseNotes}">
            <TextBlock x:Name="TxtVersion" Margin="8,0" FontSize="12" Foreground="White"/>
          </Border>
        </StackPanel>

        <Border Margin="0,4,0,0" MaxWidth="380">
          <TextBlock Text="{DynamicResource Text.About.SubTitle}" FontSize="14" TextWrapping="Wrap"/>
        </Border>

        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
          <TextBlock Text="{DynamicResource Text.About.ForkLine}"
                     Foreground="{DynamicResource Brush.FG2}"
                     VerticalAlignment="Center"/>
          <TextBlock Margin="4,0,0,0"
                     Text="{DynamicResource Text.About.UpstreamName}"
                     Foreground="{DynamicResource Brush.Accent}"
                     TextDecorations="Underline"
                     Cursor="Hand"
                     VerticalAlignment="Center"
                     PointerPressed="OnVisitUpstream"/>
        </StackPanel>

        <Border Margin="0,8,0,0" MaxWidth="380">
          <TextBlock Text="{DynamicResource Text.About.Features}"
                     Foreground="{DynamicResource Brush.FG2}"
                     FontSize="12"
                     TextWrapping="Wrap"/>
        </Border>

        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
          <Button Width="18" Height="18" Classes="icon_button" Click="OnVisitSourceCode" ToolTip.Tip="https://github.com/GrantDPowellMedrock/GetHub">
            <Path Width="16" Height="16" Data="{StaticResource Icons.GitHub}"/>
          </Button>
        </StackPanel>

      </StackPanel>
    </StackPanel>
  </StackPanel>
</v:ChromelessWindow>
